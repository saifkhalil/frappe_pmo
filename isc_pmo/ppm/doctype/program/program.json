{
 "doctype": "DocType",
 "name": "Program",
 "module": "PPM",
 "engine": "InnoDB",
 "autoname": "field:program_name",
 "naming_rule": "By fieldname",
 "title_field": "program_name",
 "search_fields": "program_name,portfolio",
 "track_changes": 1,
 "field_order": [
  "program_name", "column_break_1", "portfolio", "program_manager", "company",
  "section_sched", "program_start", "program_due", "column_break_sched", "priority", "state", "multi_year",
  "section_fin", "budget", "financial_benefit", "column_break_fin", "quantitative_benefit", "qualitative_benefit",
  "column_break_fin2", "roi", "remaining_budget_allocation", "benefit_description",
  "section_kpi", "overall_health", "schedule_health", "column_break_kpi", "financial_health", "issue_health",
  "section_counts", "active_projects", "projects_on_track", "column_break_counts", "projects_at_risk", "projects_in_trouble",
  "section_desc", "description", "business_case"
 ],
 "fields": [
  {"fieldname": "program_name", "fieldtype": "Data", "label": "Program Name", "reqd": 1, "unique": 1, "in_list_view": 1, "in_global_search": 1},
  {"fieldname": "column_break_1", "fieldtype": "Column Break"},
  {"fieldname": "portfolio", "fieldtype": "Link", "label": "Portfolio", "options": "Portfolio", "in_list_view": 1},
  {"fieldname": "program_manager", "fieldtype": "Link", "label": "Program Manager", "options": "User", "in_list_view": 1},
  {"fieldname": "company", "fieldtype": "Link", "label": "Company", "options": "Company"},
  {"fieldname": "section_sched", "fieldtype": "Section Break", "label": "Schedule"},
  {"fieldname": "program_start", "fieldtype": "Date", "label": "Program Start"},
  {"fieldname": "program_due", "fieldtype": "Date", "label": "Program Due"},
  {"fieldname": "column_break_sched", "fieldtype": "Column Break"},
  {"fieldname": "priority", "fieldtype": "Select", "label": "Priority", "options": "(1) Critical\n(2) High\n(3) Moderate\n(4) Low\n(5) Optional", "default": "(3) Moderate"},
  {"fieldname": "state", "fieldtype": "Select", "label": "State", "options": "(0) Proposed\n(1) In Progress\n(2) On Hold\n(3) Closed\n(4) Cancelled", "default": "(0) Proposed", "in_list_view": 1},
  {"fieldname": "multi_year", "fieldtype": "Check", "label": "Multi-Year"},
  {"fieldname": "section_fin", "fieldtype": "Section Break", "label": "Financials"},
  {"fieldname": "budget", "fieldtype": "Currency", "label": "Budget"},
  {"fieldname": "financial_benefit", "fieldtype": "Currency", "label": "Financial Benefit"},
  {"fieldname": "column_break_fin", "fieldtype": "Column Break"},
  {"fieldname": "quantitative_benefit", "fieldtype": "Currency", "label": "Quantitative Benefit"},
  {"fieldname": "qualitative_benefit", "fieldtype": "Small Text", "label": "Qualitative Benefit"},
  {"fieldname": "column_break_fin2", "fieldtype": "Column Break"},
  {"fieldname": "roi", "fieldtype": "Float", "label": "ROI", "read_only": 1, "precision": "4"},
  {"fieldname": "remaining_budget_allocation", "fieldtype": "Currency", "label": "Remaining Budget Allocation", "read_only": 1},
  {"fieldname": "benefit_description", "fieldtype": "Small Text", "label": "Benefit Description"},
  {"fieldname": "section_kpi", "fieldtype": "Section Break", "label": "KPIs"},
  {"fieldname": "overall_health", "fieldtype": "Select", "label": "Overall Health", "options": "\nGreen\nYellow\nRed", "in_list_view": 1},
  {"fieldname": "schedule_health", "fieldtype": "Select", "label": "Schedule Health", "options": "\nGreen\nYellow\nRed"},
  {"fieldname": "column_break_kpi", "fieldtype": "Column Break"},
  {"fieldname": "financial_health", "fieldtype": "Select", "label": "Financial Health", "options": "\nGreen\nYellow\nRed"},
  {"fieldname": "issue_health", "fieldtype": "Select", "label": "Issue Health", "options": "\nGreen\nYellow\nRed"},
  {"fieldname": "section_counts", "fieldtype": "Section Break", "label": "Project Counts (rolled up)", "collapsible": 1},
  {"fieldname": "active_projects", "fieldtype": "Int", "label": "Active Projects", "read_only": 1},
  {"fieldname": "projects_on_track", "fieldtype": "Int", "label": "On Track", "read_only": 1},
  {"fieldname": "column_break_counts", "fieldtype": "Column Break"},
  {"fieldname": "projects_at_risk", "fieldtype": "Int", "label": "At Risk", "read_only": 1},
  {"fieldname": "projects_in_trouble", "fieldtype": "Int", "label": "In Trouble", "read_only": 1},
  {"fieldname": "section_desc", "fieldtype": "Section Break", "label": "Description"},
  {"fieldname": "description", "fieldtype": "Small Text", "label": "Description"},
  {"fieldname": "business_case", "fieldtype": "Text Editor", "label": "Business Case"}
 ],
 "permissions": [
  {"role": "PMO Admin", "read": 1, "write": 1, "create": 1, "delete": 1, "report": 1, "export": 1},
  {"role": "Portfolio Manager", "read": 1, "write": 1, "create": 1, "report": 1},
  {"role": "Program Manager", "read": 1, "write": 1, "create": 1, "report": 1, "if_owner": 1},
  {"role": "Project Manager", "read": 1, "report": 1}
 ]
}
